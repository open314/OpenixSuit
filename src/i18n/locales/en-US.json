      "message": "USB communication error: {{error}}\n\nPossible solutions:\n1. Check USB connection\n2. Change USB driver type\n3. Replug device",
      "title": "USB Error"
    },
    "usbInit": {
      "message": "Unable to initialize USB driver. This may be due to driver mismatch or driver not installed\n\nPossible solutions:\n1. Check if USB driver is correctly installed\n2. Try changing USB driver type (Settings → Device Settings → USB Driver)\n3. Replug the USB device\n4. Restart the application",
      "title": "USB Initialization Failed"
    },
    "usbOpen": {
      "message": "Unable to open USB device.\n\nPossible solutions:\n1. Device may be occupied by another program, please close other flashing tools\n2. Try changing USB driver type (Settings → Device Settings → USB Driver)\n3. Windows users: If using libusb, use Zadig to install libusb driver\n4. Windows users: If using WinUSB, ensure device uses vendor driver",
      "title": "Cannot Open Device"
    },
    "usbTimeout": {
      "message": "USB communication timeout.\n\nPossible solutions:\n1. Device may not be responding correctly, please reset device\n2. Check if USB connection is stable\n3. Try re-entering FEL mode",
      "title": "USB Communication Timeout"
    },
    "usbTransfer": {
      "message": "USB data transfer failed.\n\nPossible solutions:\n1. Change USB port (recommend using motherboard direct USB port)\n2. Change USB cable\n3. Avoid using USB hubs\n4. Check if device has sufficient power",
      "title": "USB Transfer Failed"
    }
  },
